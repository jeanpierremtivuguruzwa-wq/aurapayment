rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Proof files: any authenticated user can upload + read (admin needs read)
    match /proofs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Resized thumbnails
    match /thumbs/{allPaths=**} {
      allow read: if true;
    }

    // Profile photos: user can read/write their own
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Admin profile photos
    match /admin-avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}