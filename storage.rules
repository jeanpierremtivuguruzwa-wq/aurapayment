rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Proof files: any authenticated user can upload + read (admin needs read)
    match /proofs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Resized thumbnails
    match /thumbs/{allPaths=**} {
      allow read: if true;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}