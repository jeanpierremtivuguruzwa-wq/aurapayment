rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user has admin or agent role (read from their Firestore profile)
    function isAdminOrAgent() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', 'user') in ['admin', 'agent'];
    }

    // Helper: the document belongs to the current user
    function isOwner() {
      return isAuth() && resource.data.userId == request.auth.uid;
    }

    // Transactions — users see only their own; admins/agents see all
    match /transactions/{document} {
      allow read: if isOwner() || isAdminOrAgent();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner() || isAdminOrAgent();
    }

    // Orders — users see only their own; admins/agents see all
    match /orders/{document} {
      allow read: if isOwner() || isAdminOrAgent();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner() || isAdminOrAgent();
    }

    // Currency pairs — public read; only admins/agents can write
    match /currencyPairs/{document} {
      allow read: if true;
      allow write: if isAdminOrAgent();
    }

    // Rate history — only admins/agents can read or write
    match /rateHistory/{document} {
      allow read, write: if isAdminOrAgent();
    }

    // AuraChat — rooms readable/writable by admins and agents
    match /chatRooms/{roomId} {
      allow read, write: if isAdminOrAgent();
      match /messages/{msgId} {
        allow read, write: if isAdminOrAgent();
      }
    }

    // Payment methods — public read; auth required to write (admin app)
    match /paymentMethods/{document} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Cardholders — auth required (admin app only)
    match /cardholders/{document} {
      allow read, write: if isAuth();
    }

    // Cardholder withdrawals — auth required (admin app only)
    match /cardholderWithdrawals/{document} {
      allow read, write: if isAuth();
    }

    // Admin notifications — auth required (admin app only)
    match /adminNotifications/{document} {
      allow read, write: if isAuth();
    }

    // Agents — auth required (admin app only)
    match /agents/{document} {
      allow read, write: if isAuth();
    }

    // Agent permission requests — auth required
    match /permissionRequests/{document} {
      allow read, write: if isAuth();
    }

    // Currency-cardholder assignments — auth required (admin app only)
    match /currencyAssignments/{document} {
      allow read, write: if isAuth();
    }

    // Notification recipients — auth required (admin app only)
    match /notificationRecipients/{document} {
      allow read, write: if isAuth();
    }

    // Mail queue — written by Cloud Functions only (admin SDK bypasses rules)
    // Client apps never need to read/write this collection directly
    match /mail/{document} {
      allow read, write: if false;
    }

    // User profiles — users write their own; any authenticated user (admin) can read all
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth();
      allow delete: if false;
    }

    // AuraWallet — balances writable by any auth user (send-money users are signed in)
    match /walletBalances/{currency} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Wallet history — readable by admins/agents; writable by any authenticated user
    match /walletHistory/{docId} {
      allow read: if isAdminOrAgent();
      allow write: if isAuth();
    }

    // Delivery options — public read so send-money page can load providers; write by admin/agent
    match /deliveryOptions/{document} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Support tickets — users create/read their own; agents/admins read and update all
    match /supportTickets/{ticketId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdminOrAgent());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdminOrAgent());

      // Messages sub-collection
      match /messages/{msgId} {
        // User can read/write their own ticket's messages; agents/admins can read/write all
        allow read:   if isAuth() && (
          get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid
          || isAdminOrAgent()
        );
        allow create: if isAuth() && (
          get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId == request.auth.uid
          || isAdminOrAgent()
        );
        allow update, delete: if isAdminOrAgent();
      }
    }

    // App settings — admins/agents read; only admin SDK writes (Cloud Functions)
    match /appSettings/{document} {
      allow read: if isAdminOrAgent();
      allow write: if isAdminOrAgent();
    }

    // AI Proof Monitor reviews — admins/agents only
    match /proofReviews/{document} {
      allow read, write: if isAdminOrAgent();
    }

    // AI Fraud Monitor reviews — admins/agents only
    match /fraudReviews/{document} {
      allow read, write: if isAdminOrAgent();
    }

    // Aura Bars loyalty — wallets readable by owner and admin; history readable by owner and admin
    match /barsWallets/{document} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /barsHistory/{document} {
      allow read: if isAdminOrAgent();
      allow write: if isAuth();
    }
    match /barsSettings/{document} {
      allow read: if isAuth();
      allow write: if isAdminOrAgent();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}