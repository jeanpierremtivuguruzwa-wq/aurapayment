ALLOWED_EVENT_TYPES=firebase.extensions.storage-resize-images.v1.onStart,firebase.extensions.storage-resize-images.v1.onSuccess,firebase.extensions.storage-resize-images.v1.onError,firebase.extensions.storage-resize-images.v1.onCompletion,firebase.extensions.storage-resize-images.v1.onStartResize
CONTENT_FILTER_LEVEL=OFF
DELETE_ORIGINAL_FILE=false
EVENTARC_CHANNEL=projects/${param:PROJECT_ID}/locations/us-central1/channels/firebase
firebaseextensions.v1beta.function/ingressSettings=ALLOW_ALL
firebaseextensions.v1beta.function/location=us-central1
firebaseextensions.v1beta.function/maxInstances=10
firebaseextensions.v1beta.function/minInstances=0
firebaseextensions.v1beta.function/timeoutSeconds=60
firebaseextensions.v1beta.function/vpcConnectorEgressSettings=VPC_CONNECTOR_EGRESS_SETTINGS_UNSPECIFIED
FUNCTION_MEMORY=512
IMAGE_TYPE=jpeg,webp,png
IMG_BUCKET=aura-payment.appspot.com
IMG_SIZES=200x200
IS_ANIMATED=true
MAKE_PUBLIC=true
REGENERATE_TOKEN=true